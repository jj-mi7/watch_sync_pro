      "backgroundColor": "#050A10"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.casioband.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#050A10"
      },
      "package": "com.casioband.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [],
    "experiments": {
      "typedRoutes": false
    }
  }
}
