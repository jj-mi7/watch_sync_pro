<?xml version="1.0" encoding="utf-8"?>
<!--
  This file is a workaround for third-party libraries (e.g. @notifee/react-native)
  that reference rn_edit_text_material which was removed in React Native 0.74+.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetLeft="@dimen/abc_edit_text_inset_horizontal_material"
    android:insetRight="@dimen/abc_edit_text_inset_horizontal_material"
    android:insetTop="@dimen/abc_edit_text_inset_top_material"
    android:insetBottom="@dimen/abc_edit_text_inset_bottom_material">

    <selector>
        <!--
          This file is intentionally minimal. The actual styling comes from
          the system/AppCompat theme. This stub prevents resource-not-found
          errors in libraries compiled against older RN versions.
        -->
        <item android:state_enabled="false"
            android:drawable="@drawable/abc_textfield_default_mtrl_alpha" />
        <item android:drawable="@drawable/abc_textfield_activated_mtrl_alpha" />
    </selector>
</inset>
